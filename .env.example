# InterviewAI Backend API Configuration

# API Base URL (defaults to /api if not set)
# For local development with backend on same server:
# VITE_API_URL=/api

# For remote backend server:
 VITE_API_URL=http://localhost:8000
# VITE_API_URL=https://api.example.com

# Use mock API for development/testing (when real API is unavailable)
# Set to "true" to always use mock API, "false" or omit to use real API with fallback
# VITE_USE_MOCK_API=false

# Example configurations:

# Local development (backend on same server)
# VITE_API_URL=/api

# Local backend on different port
# VITE_API_URL=http://localhost:3001

# Production API
# VITE_API_URL=https://api.interviewai.com

# Always use mock API for testing
# VITE_USE_MOCK_API=true
